# ----- Función para eliminar OU.
#--------------------------------------------------------------------------------------------------------------------------
	eliminar_ou(){
		echo ""
		echo -e "${b} Eliminar Unidad Organizativa (OU)${nc}"

		# ----- Solicitud de nombre de OU.
			echo""
			read -p " Introduzca el nombre de la unidad organizativa(OU) a eliminar: " ou

		# ----- Verificar que la OU existe antes de eliminar	
		    			if ! existe_ou "$ou"; then
		        			echo""
		        			echo -e ${r}" Error: La OU '$ou' no existe.${nc}"
		        			return
		    			fi
		# ----- Mostrar contenido de la OU 
			echo ""
			echo -e "${r} La OU '$ou' que pretende eliminar contiene: ${nc}"

		listar_contenido() {
			local ou=$1
				    
		# ----- Listar usuarios de la OU.
		    	echo -e "${y} Usuarios de la OU '$ou'${nc}"
		    	echo ""
		   	 		ldapsearch -x -D "$ADMIN_DN" -w "$ADMIN_PW" -H "$LDAP_SERVER" -b "ou=$ou,$BASE_DN" "(objectClass=posixAccount)" uid | grep '^uid:' | sed 's/^uid: //'

		# ----- Listar grupos de la OU.
		    	echo -e "${y} Grupos de la OU '$ou'${nc}"
		    	echo ""
		    		ldapsearch -x -D "$ADMIN_DN" -w "$ADMIN_PW" -H "$LDAP_SERVER" -b "ou=$ou,$BASE_DN" "(objectClass=posixGroup)" cn | grep '^cn:' | sed 's/^cn: //'
		}
		
		# ----- Eliminar OU de LDAP
					echo ""
					read -p "Está apunto de eliminar la OU $ou. ¿Esta seguro? (s/n):" respuesta

					if [[ $respuesta =~ ^[sS]$ ]];then
		    			ldapdelete -x -D "$ADMIN_DN" -w "$ADMIN_PW" -H "$LDAP_SERVER" "ou=$ou,$BASE_DN"
		# ----- Verificación si el comando anterior se ha ejecutado correctamente.  
			    		if [ $? -eq 0 ]; then			  
			        		echo ""
			        		echo -e "${g}Unidad organizativa '$ou' eliminada exitosamente.${nc}"			    			
			    		else
			    			echo""
			        		echo -e "${r}Error al eliminar la unidad organizativa '$ou'.${nc}"
			    		fi
		    		else
		    			echo ""
		    			echo -e "${r} Eliminación cancelada${nc}"
		    		fi
		    
		
	}
